    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run: hydra tui",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "args": [
                "tui",
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Run: hydra server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "args": [
                "server"
            ]
        },
        {
            "name": "Run: hydra --debug spawn",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "args": [
                "--debug",
                "spawn",
                "Make a new file called 'hello.txt' with a nice speech in it"
            ]
        },
    ]
}